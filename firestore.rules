rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function optionalString(value) {
      return value == null || value is string;
    }

    function validOrder(data) {
      return data.keys().hasAll([
        'orderNumber',
        'productId',
        'quantity',
        'name',
        'phone',
        'paymentMethod',
        'paymentMethodLabel',
        'paymentReference',
        'total',
        'currency',
        'items',
        'details',
        'date',
        'userId',
        'userEmail'
      ]) &&
      data.keys().hasOnly([
        'orderNumber',
        'productId',
        'quantity',
        'name',
        'phone',
        'paymentMethod',
        'paymentMethodLabel',
        'paymentReference',
        'total',
        'currency',
        'items',
        'details',
        'date',
        'userId',
        'userEmail'
      ]) &&
      data.orderNumber is string &&
      data.orderNumber.size() > 0 &&
      data.orderNumber.size() <= 40 &&
      optionalString(data.productId) &&
      data.quantity is int &&
      data.quantity > 0 &&
      data.quantity <= 9999 &&
      data.name is string &&
      data.name.size() >= 2 &&
      data.name.size() <= 100 &&
      data.phone is string &&
      data.phone.size() >= 6 &&
      data.phone.size() <= 20 &&
      data.paymentMethod is string &&
      (data.paymentMethod == 'whatsapp' || data.paymentMethod == 'bankak') &&
      data.paymentMethodLabel is string &&
      data.paymentMethodLabel.size() > 0 &&
      data.paymentMethodLabel.size() <= 40 &&
      optionalString(data.paymentReference) &&
      data.total is string &&
      data.total.size() > 0 &&
      data.total.size() <= 50 &&
      data.currency is string &&
      data.currency.size() > 0 &&
      data.currency.size() <= 10 &&
      data.items is list &&
      data.items.size() > 0 &&
      data.items.size() <= 50 &&
      data.details is string &&
      data.details.size() > 0 &&
      data.details.size() <= 5000 &&
      data.userId is string &&
      data.userId.size() > 0 &&
      data.userId.size() <= 128 &&
      data.userEmail is string &&
      data.userEmail.size() > 0 &&
      data.userEmail.size() <= 200 &&
      data.date is timestamp;
    }

    match /orders/{orderId} {
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid &&
        validOrder(request.resource.data);
      allow get, list, delete: if request.auth != null &&
        resource.data.userId == request.auth.uid;
      allow update: if false;
    }
  }
}
